# Optional SMTP configuration for Nodemailer (leave unset to disable emailing)
# SMTP_HOST=your.smtp.host
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password

# Optional: where to deliver contact form messages (defaults to SMTP_USER)
# CONTACT_TO=recipient@example.com

# Usage:
# - If you want email delivery, copy to .env.local and fill in values
# - If you don't, you can ignore this file entirely